DB_HOST=your-supabase-db-host
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-password
DB_NAME=postgres
PORT=3001

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket-name

# Supabase (Auth)
SUPABASE_URL=https://your-project.supabase.co

# CORS
ALLOWED_ORIGINS=https://www.snaprecorder.org,https://snaprecorder.org,http://localhost:5173

# Chrome Web Store user count (update periodically from CWS dashboard)
CHROME_STORE_USERS=123

# Resend (Email)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=SnapRec <welcome@snaprecorder.org>
FOUNDER_REPLY_TO=founder@snaprecorder.org

# Broadcast scripts (optional)
# LAUNCH_DATE_TEXT=Tuesday, March 18
# TEST_EMAIL=you@gmail.com   # launch script: send to this address only
# EXTENSION_URL=...  # optional; else uses apps/web/.env (merged by send-video-editor-launch script)
