DB_HOST=your-supabase-db-host
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-password
DB_NAME=postgres
PORT=3001

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket-name

# Supabase (Auth)
SUPABASE_URL=https://your-project.supabase.co

# CORS
ALLOWED_ORIGINS=https://www.snaprecorder.org,https://snaprecorder.org,http://localhost:5173

# Chrome Web Store user count (update periodically from CWS dashboard)
CHROME_STORE_USERS=123

# Resend (Email)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=SnapRec <welcome@snaprecorder.org>
FOUNDER_REPLY_TO=founder@snaprecorder.org

# Web app base URL (used for share links in email + Paddle redirect URLs)
WEB_BASE_URL=https://www.snaprecorder.org

# Paddle (billing) — https://sandbox-vendors.paddle.com for test, https://vendors.paddle.com for prod
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
PADDLE_ENV=sandbox                        # set to "production" for live
PADDLE_PRICE_ID_PRO_MONTHLY=pri_...
# Top-up one-time prices (optional — endpoints 402 if not configured)
PADDLE_PRICE_TOPUP_5H=pri_...
PADDLE_PRICE_TOPUP_10H=pri_...
PADDLE_PRICE_TOPUP_20H=pri_...

# Phase 3: queue / resumable jobs
# When set, the AI pipeline runs through BullMQ (survives server restarts).
# Without REDIS_URL the server falls back to in-process setImmediate (Phase 1/2 behavior).
REDIS_URL=
AI_PIPELINE_CONCURRENCY=2

# AI providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=your-deepgram-api-key  # Phase 2: enables speaker diarization via Deepgram nova-2

# Broadcast scripts (optional)
# LAUNCH_DATE_TEXT=Tuesday, March 18
# TEST_EMAIL=you@gmail.com   # launch script: send to this address only
# EXTENSION_URL=...  # optional; else uses apps/web/.env (merged by send-video-editor-launch script)
